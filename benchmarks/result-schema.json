{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bootty.dev/schemas/benchmark-result.schema.json",
  "title": "Bootty normalized benchmark result row",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "terminal",
    "profile",
    "platform",
    "benchmark",
    "metric",
    "value",
    "unit"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "minLength": 1},
    "terminal": {"type": "string", "minLength": 1},
    "terminal_version": {"type": "string"},
    "profile": {"type": "string", "minLength": 1},
    "platform": {"type": "string", "minLength": 1},
    "display_server": {"type": "string"},
    "compositor": {"type": "string"},
    "gpu": {"type": "string"},
    "driver": {"type": "string"},
    "monitor_hz": {"type": ["number", "integer"]},
    "dpi_scale": {"type": ["number", "integer"]},
    "font": {"type": "string"},
    "font_size": {"type": ["number", "integer"]},
    "cols": {"type": "integer", "minimum": 1},
    "rows": {"type": "integer", "minimum": 1},
    "term": {"type": "string"},
    "benchmark": {"type": "string", "minLength": 1},
    "category": {"type": "string"},
    "workload_version": {"type": "string"},
    "run_index": {"type": "integer", "minimum": 0},
    "metric": {"type": "string", "minLength": 1},
    "value": {"type": "number"},
    "unit": {"type": "string", "minLength": 1},
    "status": {"enum": ["pass", "fail", "skip", "timeout", "unsupported", "invalidated"]},
    "correctness_status": {"enum": ["pass", "fail", "skip", "unsupported", "invalidated"]},
    "correctness_detail": {"type": "string"},
    "correctness_artifact": {"type": ["string", "null"]},
    "catch_up_status": {"enum": ["pass", "fail", "skip", "unsupported", "invalidated"]},
    "catch_up_detail": {"type": "string"},
    "catch_up_artifact": {"type": ["string", "null"]},
    "catch_up_sentinel": {"type": ["string", "null"]},
    "latency_method": {"type": ["string", "null"]},
    "capture_method": {"type": ["string", "null"]},
    "source_csv": {"type": "string"},
    "config_hash": {"type": "string"},
    "benchmark_git_commit": {"type": "string"},
    "raw_artifact": {"type": "string"}
  },
  "additionalProperties": true
}
